server {
  serverName v1!
  listen localhost:1111!
  root ../../_www/v1!
}

server {
  serverName v2!
  listen localhost:1111!
  root ../../_www/v2!
  route /redir {
    redirect 301:/redir-target!
  }

  # if root is not specified here the default root will be searched, i.e.
  # `./www`.
  # Also, if this target did not exist, we would run into a ifinite loop which
  # will be cancancelled by the browser as the `/redir` route will match it's
  # own redir. but this happens to nginx too
  route /v1 {
    redirect 301:http://v1!
  }
}
