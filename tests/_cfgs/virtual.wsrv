server {
  serverName v1!
  listen localhost:1234!
  root ../../_www/v1!

  route /post {
    methods POST GET DELETE!
    upload /post!
  }
}

server {
  serverName v2!
  listen localhost:1234!
  root ../../_www/v2!

  route /post {
    methods POST GET DELETE!
    upload /post!
  }
}

server {
  serverName vNot!
  listen localhost:1112!
  root ../../_www/vNot!
}
