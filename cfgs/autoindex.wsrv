server {
  serverName autoindexSrv!
  listen localhost:1234!

  # this will turn on autoindex for all subdirs if not explicitly tuned-off
  # in a specific route again!
  route / {
    autoindex on!
    index bla.html!
  }

  route /noauto {
    autoindex off!
  }

  route /redir-target {
    index index.html!
  }
}
